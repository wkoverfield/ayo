{
  "name": "ayo-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Ping your teammates from inside Codex and Claude. Local daemon + realtime relay + MCP/hook adapters.",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:relay": "pnpm --filter @ayo-dev/relay dev",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache",
    "release": "pnpm -r publish --access public"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
