{
  "name": "@ayo-dev/core",
  "version": "0.2.1",
  "description": "Shared message schema, wire protocol, and types for Ayo — plus Node-only client runtime under ./node.",
  "license": "MIT",
  "author": "Wilson Overfield",
  "homepage": "https://github.com/wkoverfield/ayo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wkoverfield/ayo.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/wkoverfield/ayo/issues",
  "keywords": [
    "ayo",
    "agent",
    "mcp",
    "claude",
    "codex",
    "types"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
